{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Everlasting",
  "version": "0.1.0",
  "identifier": "com.wukaijin.everlasting",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Everlasting",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "titleBarStyle": "Overlay",
        "decorations": false,
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 14
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
